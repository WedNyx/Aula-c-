# ─── Banco de dados Redis (Vercel KV ou Upstash) ───────────────────────────
# Opção A: crie um banco KV em vercel.com/dashboard → Storage → KV
# As variáveis abaixo são geradas automaticamente e adicionadas ao projeto.
KV_REST_API_URL=https://seu-banco.upstash.io
KV_REST_API_TOKEN=seu_token_aqui

# Opção B: use o Upstash diretamente (upstash.com → Redis → Create Database)
# UPSTASH_REDIS_REST_URL=https://seu-banco.upstash.io
# UPSTASH_REDIS_REST_TOKEN=seu_token_aqui

# ─── Chave da API do Claude (robô de revisão de código) ────────────────────
# Crie em: console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-...
