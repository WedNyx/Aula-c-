# ─── Banco de dados Supabase (recomendado, grátis) ───────────────────────────
# Encontre em: supabase.com → seu projeto → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # chave "service_role"

# Senha que você definiu ao criar o projeto no Supabase (usada para criar a tabela)
DATABASE_PASSWORD=sua_senha_aqui

# ─── Alternativa: Vercel KV / Upstash Redis ────────────────────────────────
# vercel.com/dashboard → Storage → Create Database → KV
# KV_REST_API_URL=https://seu-banco.upstash.io
# KV_REST_API_TOKEN=seu_token_aqui

# ─── Chave da API do Claude (robô de revisão de código) ────────────────────
# Crie em: console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-...
