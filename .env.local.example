# ─── Banco de dados Supabase (recomendado, grátis) ───────────────────────────
# Encontre em: supabase.com → seu projeto → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # chave "service_role"

# Senha que você definiu ao criar o projeto no Supabase (usada para criar a tabela)
DATABASE_PASSWORD=sua_senha_aqui

# ─── Alternativa: Vercel KV / Upstash Redis ────────────────────────────────
# vercel.com/dashboard → Storage → Create Database → KV
# KV_REST_API_URL=https://seu-banco.upstash.io
# KV_REST_API_TOKEN=seu_token_aqui

# ─── Cérebro do Nyx (escolha UMA das opções) ────────────────────────────────

# Opção A: NVIDIA NIM / Nemotron — build.nvidia.com
# Crie a chave em: build.nvidia.com → sua conta → API Keys → Generate API Key
# NVIDIA_MODEL precisa ser o nome EXATO do modelo (aparece no trecho de código
# de exemplo da página do modelo, campo "model").
NVIDIA_API_KEY=nvapi-...
NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# Opcional: modelo NVIDIA reserva, usado automaticamente se o modelo principal
# acima falhar (mesma chave, mesmo endpoint — só troca o nome do modelo).
# NVIDIA_MODEL_FALLBACK=laguna/laguna-m.1

# Opção B: Anthropic Claude
# Crie em: console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-...
