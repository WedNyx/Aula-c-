# ─── Banco de dados (escolha UMA das opções abaixo) ──────────────────────────

# Opção A: Supabase via conexão direta (RECOMENDADO)
# A tabela é criada automaticamente — não precisa rodar nenhum SQL!
# 1. Crie conta em supabase.com → New Project
# 2. Project Settings → Database → Connection string → selecione "URI" e porta 6543
# 3. Copie a string e cole aqui (substitua [YOUR-PASSWORD] pela senha do projeto)
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:[senha]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# Opção B: Vercel KV / Upstash Redis
# vercel.com/dashboard → Storage → Create Database → KV
# As variáveis abaixo são geradas automaticamente ao conectar o banco ao projeto.
# KV_REST_API_URL=https://seu-banco.upstash.io
# KV_REST_API_TOKEN=seu_token_aqui

# Opção C: Upstash diretamente (upstash.com → Redis → Create Database)
# UPSTASH_REDIS_REST_URL=https://seu-banco.upstash.io
# UPSTASH_REDIS_REST_TOKEN=seu_token_aqui

# ─── Chave da API do Claude (robô de revisão de código) ────────────────────
# Crie em: console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-...
